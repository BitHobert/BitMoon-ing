{
    "name": "bitmoon-prize-contract",
    "version": "0.0.1",
    "description": "BitMoon prize distribution smart contract for OPNet",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "asc src/index.ts --target release --measure --uncheckedBehavior never",
        "keygen": "tsx --tsconfig tsconfig.scripts.json scripts/keygen.ts",
        "deploy": "tsx --tsconfig tsconfig.scripts.json scripts/deploy.ts"
    },
    "dependencies": {
        "@btc-vision/as-bignum": "^0.1.2",
        "@btc-vision/bitcoin": "^7.0.0-rc.6",
        "@btc-vision/btc-runtime": "^1.11.0-rc.9",
        "@btc-vision/opnet-transform": "^1.2.0",
        "@btc-vision/transaction": "^1.8.0-rc.10",
        "opnet": "^1.8.1-rc.17"
    },
    "devDependencies": {
        "@btc-vision/assemblyscript": "^0.29.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.2"
    }
}
