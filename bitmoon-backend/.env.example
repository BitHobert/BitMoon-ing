# OPNet (used for address validation only — no contract calls during gameplay)
OPNET_RPC_URL=https://testnet.opnet.org
OPNET_NETWORK=testnet

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bitmoon

# Server
HTTP_PORT=3000
WS_PORT=3001

# Auth — use a long random string in production
JWT_SECRET=change_me_in_production_use_long_random_string

# Admin (protects giveaway snapshot endpoints)
# Anyone with this secret can freeze leaderboard snapshots for prizes
ADMIN_SECRET=change_me_strong_admin_secret

# Game Config
# Starting supply: 1 billion tokens (8 decimal places handled internally)
INITIAL_SUPPLY=1000000000

DEV_MODE=true

# ── Tournament System ──────────────────────────────────────────────────────────

# Entry token mode:
#   Empty = native BTC (satoshis) — wallet sends BTC directly to PRIZE_CONTRACT_ADDRESS
#   Set   = OP-20 token transfer (requires deployed token contract)
ENTRY_TOKEN_ADDRESS=

# Entry fees in satoshis (native BTC) or raw token units (OP-20)
# 8 decimals: 1 BTC = 100_000_000 sats. Example: 1000 = 0.00001 BTC
DAILY_ENTRY_FEE=1000
WEEKLY_ENTRY_FEE=2000
MONTHLY_ENTRY_FEE=10000

# Minimum on-chain confirmations before an entry is considered verified (default: 1)
MIN_PAYMENT_CONFIRMATIONS=1

# Block-based tournament timing
# The OPNet block number where tournament counting begins. Set once at launch, never change.
TOURNAMENT_GENESIS_BLOCK=0
# Durations: daily=140 active / weekly=980 / monthly=3920 (all with 4-block gap between periods)
# Prize is sent to winner at endBlock+1; next tournament starts at endBlock+5.

# ── Prize Distribution Smart Contract ─────────────────────────────────────────

# Address that receives entry fee payments.
# Native BTC mode: use a P2TR address (e.g. operator wallet)
# OP-20 mode: use the PrizeDistributor contract address
PRIZE_CONTRACT_ADDRESS=YOUR_P2TR_ADDRESS_HERE

# Operator wallet — signs recordEntry() and distributePrize() on-chain transactions
# Use WIF (Wallet Import Format) private key — KEEP THIS SECRET, never commit to git
OPERATOR_PRIVATE_KEY=YOUR_WIF_PRIVATE_KEY_HERE

# MLDSA (quantum-resistant) private key for the operator wallet, in hex or Base58
# Required by the @btc-vision/transaction Wallet constructor alongside the classical WIF
OPERATOR_MLDSA_KEY=YOUR_MLDSA_PRIVATE_KEY_HERE

# Corresponding P2TR (Taproot) address for the operator wallet above
# Used as the refund-to address for operator transactions
OPERATOR_P2TR_ADDRESS=YOUR_P2TR_ADDRESS_HERE

# How often (in ms) the prize watcher polls for tournaments that need distributing (default: 30s)
PRIZE_WATCHER_INTERVAL_MS=30000

# ── BTC Prize Distribution (native BTC from operator wallet) ─────────────────

# Enable native BTC prizes sent to tournament winners from the operator wallet
BTC_PRIZE_ENABLED=false

# Prize amounts in satoshis for 1st/2nd/3rd place
BTC_PRIZE_1ST_SATS=50000
BTC_PRIZE_2ND_SATS=25000
BTC_PRIZE_3RD_SATS=10000
